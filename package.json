{
  "name": "upsun-sdk-node",
  "version": "0.3.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "run": "node dist/index.js",
    "build": "tsc -p tsconfig.json ",
    "build:watch": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "gen-client": "./scripts/gen_node.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "release-version": "bash ./scripts/release-version.sh $npm_config_tag"
  },
  "keywords": [],
  "author": "Mickael GAILLARD",
  "license": "Apache v2.0",
  "description": "Upsun SDK for Node.js",
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@openapitools/openapi-generator-cli": "^2.23.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.1",
    "eslint": "^9.35.0",
    "jest": "^30.1.3",
    "nock": "^14.0.10",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "quicktype": "^23.2.6",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0"
  },
  "dependencies": {
    "dotenv": "^17.2.2"
  }
}
